<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setup Required"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grant these permissions, then transfer ownership from TestDPC."
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="24dp" />

        <!-- Permission status display -->
        <TextView
            android:id="@+id/tvPermissionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textColor="#333333"
            android:layout_marginBottom="24dp" />

        <!-- Grant button -->
        <Button
            android:id="@+id/btnGrantPermissions"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="GRANT ALL PERMISSIONS"
            android:layout_marginBottom="12dp" />

        <!--
            FIX BUG #1: This is now "Done — Go to TestDPC", not "Continue to Enrollment".
            After tapping, dealer opens TestDPC and transfers ownership.
            EmiLock launches automatically into EnrollmentActivity after transfer.
        -->
        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Done — Go to TestDPC"
            android:enabled="false"
            android:layout_marginBottom="24dp" />

        <!-- Shown after all permissions granted — explains next steps to dealer -->
        <TextView
            android:id="@+id/tvTransferInstructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant all permissions above, then tap the button."
            android:textSize="14sp"
            android:textColor="#444444"
            android:background="#F0F8FF"
            android:padding="16dp"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>
</ScrollView>