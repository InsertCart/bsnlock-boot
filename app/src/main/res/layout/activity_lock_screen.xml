                                android:layout_height="wrap_content"
                                android:text="Sandeep Mobile"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Retailer Name Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/info_row_background"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_person"
                            app:tint="@color/icon_color" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Retailer"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:textStyle="bold"
                                android:alpha="0.7" />

                            <TextView
                                android:id="@+id/tvRetailerName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sandeep"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Phone Row with Call Button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/info_row_background"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_phone_call"
                            app:tint="@color/icon_color" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phone"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:textStyle="bold"
                                android:alpha="0.7" />

                            <TextView
                                android:id="@+id/tvRetailerPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="9034888517"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_call_retailer"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Call"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            app:icon="@drawable/ic_phone_outline"
                            app:iconSize="18dp"
                            app:iconPadding="4dp"
                            app:cornerRadius="20dp"
                            android:visibility="gone"
                            app:backgroundTint="@color/success"
                            android:paddingHorizontal="16dp"
                            style="@style/Widget.Material3.Button.ElevatedButton" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

